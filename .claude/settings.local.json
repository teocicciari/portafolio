{
  "permissions": {
    "allow": [
      "Bash(where:*)",
      "Bash(npx ttf2woff2:*)",
      "Bash(rm ajedrez.html chess.html chess.css chess.js feriantes.html feriantes.css)",
      "Bash(rm img/frame.png img/profile.jpg img/qr-feriantes.svg)",
      "Bash(rm -rf img/test)",
      "Bash(rm img/proyectos/arcano.webp img/proyectos/serenity.webp img/proyectos/travellers.webp img/proyectos/terminalsuites.png)",
      "Bash(rm disenos/artistica.html disenos/minimalista.html)",
      "Bash(python3 -c \":*)",
      "Bash(node -e \":*)",
      "Bash(node _add_i18n.js)",
      "Bash(node:*)",
      "Bash(npx html-validate:*)"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx html-validate index.html && echo '✅ HTML válido'"
          }
        ]
      }
    ]
  }
}
